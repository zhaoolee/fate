{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fate",
  "version": "0.1.4",
  "identifier": "com.zhaoolee.fate",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "beforeBuildCommand": "npm run web:build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Fate精力管理",
        "url": "index.html",
        "x": 0,
        "y": 0,
        "width": 390,
        "height": 631,
        "minWidth": 320,
        "minHeight": 320,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:fate.db"]
    }
  }
}
